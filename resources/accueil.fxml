<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="680.0" prefWidth="1050.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="AccueilController"
            stylesheets="@style.css"
            styleClass="main-bg">
    <children>
        
        <AnchorPane layoutX="0" layoutY="0" prefWidth="235" prefHeight="680" styleClass="sidebar">
            <children>
                <Label layoutX="25" layoutY="30" text="TuneMood" styleClass="logo" />
                <Button layoutX="20" layoutY="90" prefWidth="190" text="👤 Profils" onAction="#ouvrirProfils" styleClass="nav-button" />
                <Button layoutX="20" layoutY="135" prefWidth="190" text="🏠 Accueil" onAction="#ouvrirAccueil" styleClass="nav-button" />
                <Button layoutX="20" layoutY="180" prefWidth="190" text="🎵 Bibliothèque" onAction="#ouvrirBibliotheque" styleClass="nav-button" />
                <Button layoutX="20" layoutY="225" prefWidth="190" text="❤️ Favoris" onAction="#ouvrirFavoris" styleClass="nav-button" />
                <Button layoutX="20" layoutY="270" prefWidth="190" text="📂 Playlists" onAction="#ouvrirPlaylists" styleClass="nav-button" />
                <Button layoutX="20" layoutY="315" prefWidth="190" text="📊 Statistiques" onAction="#ouvrirStatistiques" styleClass="nav-button" />
                <Button layoutX="20" layoutY="360" prefWidth="190" text="ℹ À propos" onAction="#ouvrirAPropos" styleClass="nav-button" />
                <Label layoutX="25" layoutY="455" text="Mini Spotify local" style="-fx-text-fill: #ff2b2b; -fx-font-weight: bold;" />
                <Label layoutX="25" layoutY="485" text="JavaFX + POO" style="-fx-text-fill: #999999;" />
            </children>
        </AnchorPane>
    

        <Label layoutX="275" layoutY="30" text="Accueil" styleClass="title" />
        <Label fx:id="profilLabel" layoutX="280" layoutY="84" text="Profil :" styleClass="label-light" />

        <ListView fx:id="musiqueList" layoutX="275" layoutY="120" prefHeight="350" prefWidth="520" />

        <Button text="+ Ajouter" layoutX="830" layoutY="125" prefWidth="130" prefHeight="38"
                onAction="#ajouterMusique" styleClass="red-button" />
        <Button text="Supprimer" layoutX="830" layoutY="180" prefWidth="130" prefHeight="38"
                onAction="#supprimerMusique" styleClass="dark-button" />
        <Button text="♥ Favori" layoutX="830" layoutY="235" prefWidth="130" prefHeight="38"
                onAction="#ajouterFavori" styleClass="dark-button" />

        <AnchorPane layoutX="255" layoutY="500" prefWidth="770" prefHeight="160" styleClass="panel">
            <children>
                <Label fx:id="titreLectureLabel" layoutX="25" layoutY="20" text="Aucune musique en lecture"
                       style="-fx-text-fill: white; -fx-font-weight: bold;" />

                <Slider fx:id="progressSlider" layoutX="230" layoutY="23" prefWidth="350" />
                <Label fx:id="tempsLabel" layoutX="595" layoutY="20" text="00:00 / 00:00" styleClass="label-light" />

                <Button text="🎲" layoutX="230" layoutY="75" prefWidth="50" prefHeight="38"
                        onAction="#randomMusique" styleClass="dark-button" />
                <Button text="▶" layoutX="295" layoutY="75" prefWidth="50" prefHeight="38"
                        onAction="#jouerMusique" styleClass="red-button" />
                <Button text="⏸" layoutX="360" layoutY="75" prefWidth="50" prefHeight="38"
                        onAction="#pauseMusique" styleClass="dark-button" />
                <Button text="⏹" layoutX="425" layoutY="75" prefWidth="50" prefHeight="38"
                        onAction="#stopMusique" styleClass="dark-button" />

                <HBox fx:id="equalizerBox" layoutX="25" layoutY="75" prefWidth="170" prefHeight="70" spacing="5" alignment="BOTTOM_LEFT" />

                <Label layoutX="585" layoutY="84" text="Volume" styleClass="label-light" />
                <Slider fx:id="volumeSlider" layoutX="650" layoutY="88" prefWidth="90" />
            </children>
        </AnchorPane>

    </children>
</AnchorPane>
